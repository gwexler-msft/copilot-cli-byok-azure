{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "CI profile — COMMERCIAL DEV (AzureCloud, ephemeral). Diff from ci.commercial.json: envName=comm-dev (separate VNet/RG), tiny model capacity (25 TPM each — smoke probes only), runner stack ON (smoke-test workflow targets `runs-on: comm-dev`). Designed to be torn down nightly by teardown-dev.yml so monthly cost stays near $0 between push events. Auto-deployed by deploy.yml on push to main, never by manual dispatch (pilots stay manual-only forever). The runner PAT is supplied via `ghRunnerPat` -> `azd env set GH_RUNNER_PAT` on first push (one-time bootstrap, then KEDA polls).",
  "parameters": {
    "namePrefix":         { "value": "copilot-byok" },
    "envName":            { "value": "comm-dev" },
    "location":           { "value": "eastus2" },
    "cloudEnv":           { "value": "AzureCloud" },
    "vnetCidr":           { "value": "10.61.0.0/16" },
    "apimSku":            { "value": "Developer" },
    "apimPublisherEmail": { "value": "${APIM_PUBLISHER_EMAIL}" },
    "apimPublisherName":  { "value": "Copilot BYOK Gateway (DEV)" },
    "modelName":          { "value": "gpt-5.1" },
    "modelVersion":       { "value": "2025-11-13" },
    "modelDeploymentSku": { "value": "GlobalStandard" },
    "modelCapacity":      { "value": 25 },
    "apimExposedModelName": { "value": "gpt-5.1" },
    "deployAoai":         { "value": false },
    "deployFoundry":      { "value": true },
    "foundryModelName":   { "value": "gpt-5.1" },
    "foundryModelVersion": { "value": "2025-11-13" },
    "foundryModelDeploymentSku": { "value": "GlobalStandard" },
    "foundryModelCapacity": { "value": 25 },
    "foundryExposedModelName": { "value": "gpt-5.1" },
    "aoaiPinnedModels":   { "value": "" },
    "deployMiniModel":    { "value": true },
    "miniModelName":      { "value": "gpt-4.1-mini" },
    "miniModelVersion":   { "value": "2025-04-14" },
    "miniModelDeploymentSku": { "value": "GlobalStandard" },
    "miniModelCapacity":  { "value": 25 },
    "miniExposedModelName": { "value": "gpt-4.1-mini" },
    "autoRouteSentinel":  { "value": "auto" },
    "autoRouteLengthThreshold": { "value": 500 },
    "autoRouteAmbiguousBand": { "value": 200 },
    "autoRouteClassifierEnabled": { "value": false },
    "authMode":           { "value": "subscriptionKey" },
    "deployTestSubscriptions": { "value": true },
    "testSubscriptions":  { "value": [ { "name": "dev1", "product": "byok-standard" }, { "name": "dev2", "product": "byok-power" } ] },
    "productTiers":       { "value": [
      { "name": "byok-standard", "displayName": "BYOK Standard", "description": "Standard developer tier.", "callsPerMinute": 60, "tokensPerMinute": 20000, "monthlyCallQuota": 50000 },
      { "name": "byok-power", "displayName": "BYOK Power", "description": "Power developer tier (sized for VS Code Copilot Chat with full codebase context).", "callsPerMinute": 120, "tokensPerMinute": 200000, "monthlyCallQuota": 200000 }
    ] },
    "jwtDefaultCallsPerMinute":  { "value": 120 },
    "jwtDefaultTokensPerMinute": { "value": 200000 },
    "jwtDefaultMonthlyCallQuota": { "value": 200000 },
    "raiPolicyName":      { "value": "byok-coding" },
    "entraTenantId":      { "value": "${ENTRA_TENANT_ID}" },
    "apiAppIdUri":        { "value": "${API_APP_ID_URI}" },
    "apiAudience":        { "value": "${API_AUDIENCE}" },
    "requiredScope":      { "value": "cli.invoke" },
    "deployVpnGateway":   { "value": false },
    "vpnRootCertPublicData": { "value": "" },
    "peerVnetResourceId": { "value": "" },
    "deployerPrincipalId": { "value": "" },
    "assignAoaiRbac":     { "value": false },
    "playgroundPrincipalIds": { "value": [] },
    "playgroundPrincipalType": { "value": "User" },
    "deployTestStack":  { "value": false },
    "deployTestVm":       { "value": false },
    "deployNatGateway":   { "value": true },
    "restrictVmEgress":   { "value": true },
    "restrictApimEgress": { "value": true },
    "testVmAdminUsername": { "value": "byokadmin" },
    "deployApimPrivateDns": { "value": true },
    "deployBackendPool":  { "value": false },
    "backendPoolStrategy": { "value": "priority" },
    "foundryRegions":     { "value": [] },
    "aoaiRegions":        { "value": [] },
    "enableBackendCircuitBreaker": { "value": true },
    "breakerFailureCount": { "value": 5 },
    "breakerInterval":    { "value": "PT1M" },
    "breakerTripDuration": { "value": "PT1M" },
    "deployGhRunner":     { "value": true },
    "ghRunnerFicEnvSubjects": { "value": [ "comm-dev" ] },
    "ghRunnerPat":        { "value": "${GH_RUNNER_PAT}" }
  }
}
