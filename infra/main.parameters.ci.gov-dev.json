{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "_comment": "CI profile — GOVERNMENT DEV (AzureUSGovernment, ephemeral). Diff from ci.gov.json: envName=gov-dev, tiny model capacity (25 TPM each), runner stack ON. Designed to be torn down nightly by teardown-dev.yml. Auto-deployed by deploy.yml on push to main, never by manual dispatch (pilots stay manual-only forever). Runner image: dev intentionally stays on the PUBLIC github-runner image (useAcrRunnerImage=false), unlike the pilots (true). The dev runner is a dormant parity placeholder (no workflow targets its [self-hosted, gov-dev] label), and dev is ephemeral — ACA validates the ACR image manifest at provision time, but the ACR is recreated empty on each re-provision, so baking would require a fragile two-pass provision for zero functional gain.",
  "_comment_commercial": "Commercial Foundry route (parallel /openai-commercial path) ENABLED for gov-dev (validated 2026-07-01: the gov-dev gateway returned HTTP 200 from a Commercial Foundry for chat + responses). Backend auth = servicePrincipal (client secret): the secretless servicePrincipalFederated mode is BLOCKED cross-sovereign-cloud (Commercial Entra rejects the Gov managed-identity token as a federated credential with AADSTS700238), so Gov->Commercial MUST use a client secret. Requires on the gov-dev environment: repo Variables COMMERCIAL_TENANT_ID, COMMERCIAL_CLIENT_ID, COMMERCIAL_FOUNDRY_BASE_URL; secret COMMERCIAL_FOUNDRY_CLIENT_SECRET. Egress allows BOTH the commercial Foundry data endpoint AND commercial AAD login.microsoftonline.com CIDRs (NSGs can't match FQDNs; refresh if they drift). Caller token is NEVER forwarded. Set deployFoundryCommercial=false to disable. See docs/commercial-foundry-route.md.",
  "parameters": {
    "namePrefix":         { "value": "copilot-byok" },
    "envName":            { "value": "gov-dev" },
    "location":           { "value": "usgovvirginia" },
    "cloudEnv":           { "value": "AzureUSGovernment" },
    "vnetCidr":           { "value": "10.61.0.0/16" },
    "apimSku":            { "value": "Developer" },
    "apimPublisherEmail": { "value": "${APIM_PUBLISHER_EMAIL}" },
    "apimPublisherName":  { "value": "Copilot BYOK Gateway (DEV)" },
    "modelName":          { "value": "gpt-5.1" },
    "modelVersion":       { "value": "2025-11-13" },
    "modelDeploymentSku": { "value": "DataZoneStandard" },
    "modelCapacity":      { "value": 25 },
    "apimExposedModelName": { "value": "gpt-5.1" },
    "deployAoai":         { "value": false },
    "deployFoundry":      { "value": true },
    "foundryModelName":   { "value": "gpt-5.1" },
    "foundryModelVersion": { "value": "2025-11-13" },
    "foundryModelDeploymentSku": { "value": "DataZoneStandard" },
    "foundryModelCapacity": { "value": 25 },
    "foundryExposedModelName": { "value": "gpt-5.1" },
    "aoaiPinnedModels":   { "value": "" },
    "deployFoundrySubkeyProxy": { "value": true },
    "deployFoundryCommercial":             { "value": true },
    "foundryCommercialBaseUrl":            { "value": "${COMMERCIAL_FOUNDRY_BASE_URL}" },
    "foundryCommercialApiName":            { "value": "copilot-byok-foundry-commercial" },
    "foundryCommercialApiPath":            { "value": "openai-commercial" },
    "foundryCommercialApiVersion":         { "value": "2025-04-01-preview" },
    "foundryCommercialAuthMode":           { "value": "servicePrincipal" },
    "foundryCommercialTenantId":           { "value": "${COMMERCIAL_TENANT_ID}" },
    "foundryCommercialClientId":           { "value": "${COMMERCIAL_CLIENT_ID}" },
    "foundryCommercialClientSecret":       { "value": "${COMMERCIAL_FOUNDRY_CLIENT_SECRET}" },
    "foundryCommercialTokenResource":      { "value": "https://cognitiveservices.azure.com" },
    "foundryCommercialAuthorityHost":      { "value": "login.microsoftonline.com" },
    "foundryCommercialAudience":           { "value": "" },
    "foundryCommercialEgressDestinations": { "value": [ "20.190.128.0/18", "40.126.0.0/18", "20.40.225.0/24", "20.62.58.0/24" ] },
    "addCommercialToProductTiers":         { "value": true },
    "deployMiniModel":    { "value": true },
    "miniModelName":      { "value": "gpt-4.1-mini" },
    "miniModelVersion":   { "value": "2025-04-14" },
    "miniModelDeploymentSku": { "value": "DataZoneStandard" },
    "miniModelCapacity":  { "value": 25 },
    "miniExposedModelName": { "value": "gpt-4.1-mini" },
    "autoRouteSentinel":  { "value": "auto,byok-auto" },
    "autoRouteLengthThreshold": { "value": 500 },
    "autoRouteAmbiguousBand": { "value": 200 },
    "autoRouteClassifierEnabled": { "value": false },
    "authMode":           { "value": "subscriptionKey" },
    "deployTestSubscriptions": { "value": true },
    "testSubscriptions":  { "value": [ { "name": "dev1", "product": "byok-standard" }, { "name": "dev2", "product": "byok-power" } ] },
    "productTiers":       { "value": [
      { "name": "byok-standard", "displayName": "BYOK Standard", "description": "Standard developer tier.", "callsPerMinute": 60, "tokensPerMinute": 20000, "monthlyCallQuota": 50000 },
      { "name": "byok-power", "displayName": "BYOK Power", "description": "Power developer tier (sized for VS Code Copilot Chat with full codebase context).", "callsPerMinute": 120, "tokensPerMinute": 200000, "monthlyCallQuota": 200000 }
    ] },
    "jwtDefaultCallsPerMinute":  { "value": 120 },
    "jwtDefaultTokensPerMinute": { "value": 200000 },
    "jwtDefaultMonthlyCallQuota": { "value": 200000 },
    "raiPolicyName":      { "value": "byok-coding" },
    "entraTenantId":      { "value": "${ENTRA_TENANT_ID}" },
    "apiAppIdUri":        { "value": "${API_APP_ID_URI}" },
    "apiAudience":        { "value": "${API_AUDIENCE}" },
    "requiredScope":      { "value": "cli.invoke" },
    "deployVpnGateway":   { "value": false },
    "vpnRootCertPublicData": { "value": "" },
    "peerVnetResourceId": { "value": "" },
    "deployerPrincipalId": { "value": "" },
    "assignAoaiRbac":     { "value": false },
    "playgroundPrincipalIds": { "value": [] },
    "playgroundPrincipalType": { "value": "User" },
    "deployTestStack":  { "value": false },
    "deployTestVm":       { "value": false },
    "deployNatGateway":   { "value": true },
    "restrictVmEgress":   { "value": true },
    "restrictApimEgress": { "value": true },
    "testVmAdminUsername": { "value": "byokadmin" },
    "deployApimPrivateDns": { "value": true },
    "deployBackendPool":  { "value": false },
    "backendPoolStrategy": { "value": "priority" },
    "foundryRegions":     { "value": [] },
    "aoaiRegions":        { "value": [] },
    "enableBackendCircuitBreaker": { "value": true },
    "breakerFailureCount": { "value": 5 },
    "breakerInterval":    { "value": "PT1M" },
    "breakerTripDuration": { "value": "PT1M" },
    "deployGhRunner":     { "value": true },
    "useAcrRunnerImage":  { "value": false },
    "restrictRunnerEgress": { "value": false },
    "ghRunnerAuthMode":   { "value": "pat" },
    "ghAppId":            { "value": "${GH_APP_ID}" },
    "ghAppInstallationId": { "value": "${GH_APP_INSTALLATION_ID}" },
    "ghAppPrivateKey":    { "value": "${GH_APP_PRIVATE_KEY}" },
    "ghRunnerFicEnvSubjects": { "value": [ "gov-dev" ] },
    "ghRunnerPat":        { "value": "${GH_RUNNER_PAT}" },
    "deployRegisterApp":  { "value": true },
    "registerEasyAuthClientId": { "value": "${REGISTER_EASYAUTH_CLIENT_ID}" },
    "registerEasyAuthSecretKeyVaultUri": { "value": "${REGISTER_EASYAUTH_SECRET_KV_URI}" },
    "registerPrivateNetworking": { "value": false }
  }
}
